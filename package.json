 "main": "./dist/index.js",
 "types": "./dist/index.d.ts",
 "exports": {
  ".": {
   "import": "./dist/index.js",
   "types": "./dist/index.d.ts"
  }
 },
 "files": [
  "dist",
  "README.md"
 ],
 "publishConfig": {
  "registry": "https://npm.pkg.github.com"
 },
 "repository": {
  "type": "git",
  "url": "https://github.com/TitoHansen/meu-design-system.git"
 },
